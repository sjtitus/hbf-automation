# --- Python ---
venv/
__pycache__/
*.pyc

# --- Editor / OS ---
.DS_Store
.claude/settings.local.json

# --- Sensitive: customer master ---
# Master customer list contains business-confidential names. Stays local.
data/*.xls
data/*.xlsx
data/*.csv

# --- Sensitive: per-vendor input drop-zones ---
# All contents are real customer materials. Track only the .gitkeep
# placeholder so the directories exist after a fresh clone.
badger-invoices/*
!badger-invoices/.gitkeep
scotlyn-invoices/*
!scotlyn-invoices/.gitkeep
mrs-invoices/*
!mrs-invoices/.gitkeep

# --- Sensitive: test fixtures ---
# PDFs and golden outputs reference real customer data — track only the
# .gitkeep so the directory layout exists after a fresh clone.
tests/fixtures/*
!tests/fixtures/.gitkeep

# --- Generated runtime artifacts ---
logs/
quickbooks-imports/

# --- BOL extraction tool outputs (renders of real customer BOLs) ---
ship_to_crops/
ship_to_crops_loose/
shipto_bounds/

# --- Misc legacy / secrets ---
.qb-browser-profile/
.env
